@inherits LayoutComponentBase
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@700&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --bg: #0f0f11;
        --surface: #18181c;
        --surface2: #222228;
        --border: rgba(255,255,255,0.07);
        --accent: #e8ff47;
        --text: #f0f0f0;
        --muted: #666666;
        --nav-h: 68px;
        --top-h: 52px;
    }

    html, body {
        background: var(--bg);
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        height: 100%;
    }

    /* ── LAYOUT WRAPPER ── */
    .ml-shell {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: var(--bg);
    }

    /* ── TOPBAR ── */
    .ml-topbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: var(--top-h);
        background: var(--bg);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        z-index: 100;
    }

    .ml-logo {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .ml-logo-icon {
        width: 28px; height: 28px;
        background: var(--accent);
        border-radius: 7px;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px;
    }
    .ml-logo-text {
        font-size: 14px;
        font-weight: 600;
        letter-spacing: -0.3px;
    }
    .ml-logo-text span { color: var(--accent); }

    .ml-user {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .ml-user-name {
        font-size: 12px;
        color: var(--muted);
        max-width: 120px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .ml-logout {
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--muted);
        font-family: 'DM Sans', sans-serif;
        font-size: 12px;
        padding: 5px 12px;
        cursor: pointer;
        transition: color 0.15s, border-color 0.15s;
        white-space: nowrap;
    }
    .ml-logout:hover {
        color: #f87171;
        border-color: rgba(248,113,113,0.35);
    }

    /* ── PAGE CONTENT ── */
    .ml-page {
        margin-top: var(--top-h);
        margin-bottom: var(--nav-h);
        flex: 1;
        overflow-y: auto;
    }

    /* ── BOTTOM NAV ── */
    .ml-nav {
        position: fixed;
        bottom: 0; left: 0; right: 0;
        height: var(--nav-h);
        background: var(--surface);
        border-top: 1px solid var(--border);
        display: flex;
        align-items: stretch;
        z-index: 100;
        padding: 0 4px;
        padding-bottom: env(safe-area-inset-bottom);
    }

    .ml-nav-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        text-decoration: none;
        color: var(--muted);
        border-radius: 10px;
        margin: 6px 2px;
        padding: 0 4px;
        transition: color 0.15s, background 0.15s;
        cursor: pointer;
        position: relative;
    }
    .ml-nav-item:hover {
        color: var(--text);
        background: var(--surface2);
    }
    .ml-nav-item.active {
        color: var(--accent);
    }
    .ml-nav-item.active .ml-nav-dot {
        opacity: 1;
    }

    .ml-nav-icon { font-size: 20px; line-height: 1; }
    .ml-nav-label {
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.3px;
        white-space: nowrap;
    }

    /* indicador ativo */
    .ml-nav-dot {
        position: absolute;
        top: 6px;
        width: 4px; height: 4px;
        border-radius: 50%;
        background: var(--accent);
        opacity: 0;
        transition: opacity 0.2s;
    }
</style>

<div class="ml-shell">

    <!-- TOPBAR -->
    <div class="ml-topbar">
        <div class="ml-logo">
            <div class="ml-logo-icon">🔧</div>
            <div class="ml-logo-text">Garagem<span>75</span></div>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="ml-user">
                    <span class="ml-user-name">@context.User.Identity?.Name</span>
                    <button class="ml-logout" @onclick="Logout">Sair</button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    <!-- CONTEÚDO -->
    <div class="ml-page">
        @Body
    </div>

    <!-- BOTTOM NAV -->
    
    @* Só mostra o menu se NÃO estiver na página de login *@
    @if (!IsLoginPage)
    {
        <nav class="ml-nav">

            <a href="/" class="ml-nav-item @(IsActive("/dashboard") || Nav.Uri.TrimEnd('/').EndsWith(Nav.BaseUri.TrimEnd('/')) ? "active" : "")">
                <div class="ml-nav-dot"></div>
                <span class="ml-nav-icon">📊</span>
                <span class="ml-nav-label">Dashboard</span>
            </a>

            <a href="/clientes" class="ml-nav-item @(IsActive("/clientes") ? "active" : "")">
                <div class="ml-nav-dot"></div>
                <span class="ml-nav-icon">👤</span>
                <span class="ml-nav-label">Clientes</span>
            </a>

            <a href="/veiculos" class="ml-nav-item @(IsActive("/veiculos") ? "active" : "")">
                <div class="ml-nav-dot"></div>
                <span class="ml-nav-icon">🚗</span>
                <span class="ml-nav-label">Veículos</span>
            </a>

            <AuthorizeView Roles="Administrador,Mecanico">
                <a href="/os" class="ml-nav-item @(IsActive("/os") ? "active" : "")">
                    <div class="ml-nav-dot"></div>
                    <span class="ml-nav-icon">🛠️</span>
                    <span class="ml-nav-label">OS</span>
                </a>
            </AuthorizeView>

            <AuthorizeView Roles="Administrador">
                <a href="/pecas" class="ml-nav-item @(IsActive("/pecas") ? "active" : "")">
                    <div class="ml-nav-dot"></div>
                    <span class="ml-nav-icon">🔩</span>
                    <span class="ml-nav-label">Peças</span>
                </a>
                <a href="/usuarios" class="ml-nav-item @(IsActive("/usuarios") ? "active" : "")">
                    <div class="ml-nav-dot"></div>
                    <span class="ml-nav-icon">👥</span>
                    <span class="ml-nav-label">Usuários</span>
                </a>

            </AuthorizeView>

        </nav>

    }

</div>

@code {
    private bool IsLoginPage => Nav.Uri.ToLower().EndsWith("/login") || Nav.Uri.ToLower().EndsWith("/");

    protected override void OnInitialized()
    {
        // Garante que o layout atualize quando a rota mudar
        Nav.LocationChanged += (s, e) => StateHasChanged();
    }

    bool IsActive(string url)
        => Nav.Uri.Contains(url, StringComparison.OrdinalIgnoreCase);

    async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "token");
        Nav.NavigateTo("/login", true);
    }
}
