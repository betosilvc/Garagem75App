@page "/os/nova"
@inject OrdemServicoApi Api
@inject NavigationManager Nav

<h3>Nova Ordem de Serviço</h3>

<div class="form-group">
    <label>Mão de obra</label>
    <input type="number" @bind="model.MaoDeObra" class="form-control" />
</div>

<div class="form-group">
    <label>Desconto</label>
    <input type="number" @bind="model.ValorDesconto" class="form-control" />
</div>

<button class="btn btn-success" @onclick="Salvar">Salvar</button>

@code {
    OrdemServicoDto model = new();

    async Task Salvar()
    {
        await Api.Create(model);
        Nav.NavigateTo("/os");
    }
}