@page "/os/nova"
@attribute [Authorize(Roles = "Administrador,Mecanico")]
@using Garagem75.Shared.Dtos
@using Garagem76.Client.Services
@using Microsoft.AspNetCore.Authorization

@inject OrdemServicoApi Api
@inject ClienteApi ClienteApi
@inject VeiculoApi VeiculoApi
@inject PecaApi PecaApi
@inject NavigationManager Nav

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@700&display=swap');

    .cli-shell {
        --bg: #0f0f11;
        --surface: #18181c;
        --surface2: #222228;
        --border: rgba(255,255,255,0.07);
        --accent: #e8ff47;
        --text: #f0f0f0;
        --muted: #888888;
        --danger: #f87171;
        --radius: 14px;
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        padding: 24px;
    }

    .os-form-container { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px; }

    /* CARDS */
    .form-section {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
    }
    .section-title { font-size: 14px; font-weight: 600; color: var(--accent); text-transform: uppercase; margin-bottom: 20px; letter-spacing: 1px; }

    /* GRID */
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .full-width { grid-column: span 2; }

    .input-group { display: flex; flex-direction: column; gap: 8px; }
    .input-group label { font-size: 13px; color: var(--muted); }

    .cli-input {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 12px 16px;
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        outline: none;
    }
    .cli-input:focus { border-color: var(--accent); }

    /* TABELA DE PEÇAS */
    .pecas-table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 13px; }
    .pecas-table th { text-align: left; color: var(--muted); padding: 8px; border-bottom: 1px solid var(--border); }
    .pecas-table td { padding: 10px 8px; border-bottom: 1px solid rgba(255,255,255,0.03); }

    /* RESUMO FINAL */
    .summary-card {
        background: var(--surface2);
        border: 1px solid var(--accent);
        border-radius: var(--radius);
        padding: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .total-box { text-align: right; }
    .total-label { font-size: 12px; color: var(--muted); }
    .total-val { font-family: 'Space Mono', monospace; font-size: 24px; color: var(--accent); font-weight: 700; display: block; }

    /* BOTÕES */
    .btn-cli { 
        padding: 14px 28px; border-radius: 10px; font-weight: 600; cursor: pointer; border: none;
        transition: 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .btn-success { background: var(--accent); color: #000; width: 100%; font-size: 16px; margin-top: 10px; }
    .btn-add { background: var(--surface2); color: var(--accent); border: 1px solid var(--accent); padding: 10px; }
    .btn-del { color: var(--danger); background: transparent; cursor: pointer; border: none; }

    @@media (max-width: 480px) { .form-grid { grid-template-columns: 1fr; } .full-width { grid-column: span 1; } }
</style>

<div class="cli-shell">
    <div class="os-form-container">
        
        <div class="cli-title">Nova Ordem de Serviço<span>.</span></div>

        @* 1. CLIENTE E VEÍCULO *@
        <div class="form-section">
            <div class="section-title">1. Identificação</div>
            <div class="form-grid">
                <div class="input-group">
                    <label>Cliente</label>
                    <select class="cli-input" @bind="model.ClienteId" @bind:after="CarregarVeiculos">
                        <option value="0">Selecione o cliente...</option>
                        @foreach (var c in clientes)
                        {
                            <option value="@c.Id">@c.Nome</option>
                        }
                    </select>
                </div>
                <div class="input-group">
                    <label>Veículo</label>
                    <select class="cli-input" @bind="model.VeiculoId">
                        <option value="0">Selecione o veículo...</option>
                        @foreach (var v in veiculos)
                        {
                            <option value="@v.IdVeiculo">@v.Fabricante - @v.Modelo (@v.Placa)</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        @* 2. PEÇAS E PRODUTOS *@
        <div class="form-section">
            <div class="section-title">2. Peças e Produtos</div>
            <div style="display:flex; gap:10px; margin-bottom:20px;">
                <select class="cli-input" style="flex:2" @bind="pecaSelecionadaId">
                    <option value="0">Selecione uma peça...</option>
                    @foreach (var p in pecas)
                    {
                        <option value="@p.IdPeca">@p.Nome - R$ @p.Preco.ToString("N2")</option>
                    }
                </select>
                <input type="number" class="cli-input" style="width:100px" min="1" @bind="quantidade" />
                <button class="btn-cli btn-add" @onclick="AdicionarPeca">＋</button>
            </div>

            @if (itens.Any())
            {
                <table class="pecas-table">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Qtd</th>
                            <th>Unit.</th>
                            <th style="text-align: right;">Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in itens)
                        {
                            <tr>
                                <td>@item.NomePeca</td>
                                <td>@item.Quantidade</td>
                                <td>@item.PrecoUnitario.ToString("C2")</td>
                                <td style="text-align: right;">@((item.Quantidade * item.PrecoUnitario).ToString("C2"))</td>
                                <td style="text-align: right;">
                                    <button class="btn-del" @onclick="() => Remover(item)">✕</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        @* 3. SERVIÇO E VALORES *@
        <div class="form-section">
            <div class="section-title">3. Detalhes do Serviço</div>
            <div class="form-grid">
                <div class="input-group full-width">
                    <label>Descrição do Problema / Serviço</label>
                    <textarea class="cli-input" style="min-height: 80px;" @bind="model.Descricao" placeholder="O que será feito no carro?"></textarea>
                </div>
                <div class="input-group">
                    <label>Mão de Obra (R$)</label>
                    <input type="number" class="cli-input" @bind="model.MaoDeObra" />
                </div>
                <div class="input-group">
                    <label>Desconto (R$)</label>
                    <input type="number" class="cli-input" @bind="model.ValorDesconto" />
                </div>
                <div class="input-group full-width">
                    <label>Observações Internas</label>
                    <textarea class="cli-input" @bind="model.Observacao" placeholder="Algo importante para a oficina saber..."></textarea>
                </div>
            </div>
        </div>

        @* RESUMO E SALVAR *@
        <div class="summary-card">
            <div>
                <div class="info-label" style="color: var(--muted); font-size: 11px;">PEÇAS ACUMULADAS</div>
                <div style="font-family: 'Space Mono', monospace; font-size: 16px;">R$ @totalPecas.ToString("N2")</div>
            </div>
            <div class="total-box">
                <span class="total-label">TOTAL GERAL ESTIMADO</span>
                <span class="total-val">R$ @totalGeral.ToString("N2")</span>
            </div>
        </div>

        <button class="btn-cli btn-success" @onclick="Salvar">
            🚀 Criar Ordem de Serviço
        </button>

    </div>
</div>

@code {
    OrdemServicoDto model = new();
    List<ClienteDto> clientes = new();
    List<VeiculoDto> veiculos = new();
    List<PecaDto> pecas = new();
    List<OrdemServicoPecaDto> itens = new();

    int pecaSelecionadaId;
    int quantidade = 1;

    decimal totalPecas => itens.Sum(i => i.Quantidade * i.PrecoUnitario);
    decimal totalGeral => model.MaoDeObra + totalPecas - model.ValorDesconto;

    protected override async Task OnInitializedAsync()
    {
        clientes = await ClienteApi.GetAll();
        pecas = await PecaApi.GetAll();
    }

    async Task CarregarVeiculos()
    {
        if (model.ClienteId == 0) { veiculos.Clear(); return; }
        veiculos = await VeiculoApi.GetByCliente(model.ClienteId);
    }

    void AdicionarPeca()
    {
        var peca = pecas.FirstOrDefault(p => p.IdPeca == pecaSelecionadaId);
        if (peca == null || quantidade <= 0) return;

        var existente = itens.FirstOrDefault(i => i.PecaId == peca.IdPeca);
        if (existente != null) existente.Quantidade += quantidade;
        else
        {
            itens.Add(new OrdemServicoPecaDto {
                PecaId = peca.IdPeca,
                NomePeca = peca.Nome,
                Quantidade = quantidade,
                PrecoUnitario = peca.Preco
            });
        }
        quantidade = 1;
        pecaSelecionadaId = 0;
    }

    void Remover(OrdemServicoPecaDto item) => itens.Remove(item);

    async Task Salvar()
    {
        if (model.ClienteId == 0 || model.VeiculoId == 0) return;

        model.PecasAssociadas = itens;
        await Api.Create(model);
        Nav.NavigateTo("/os");
    }
}