@page "/pecas/novo"
@page "/pecas/editar/{id:int}"
@using Garagem75.Shared.Dtos
@using Garagem76.Client.Services
@inject HttpClient Http
@inject PecaApi Api
@inject NavigationManager Nav

<h3>@(id == null ? "Nova Peça" : "Editar Peça")</h3>

<EditForm Model="peca" OnValidSubmit="Salvar">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-group">
        <label>Código</label>
        <InputNumber class="form-control" @bind-Value="peca.CodPeca" />
    </div>

    <div class="form-group">
        <label>Nome</label>
        <InputText class="form-control" @bind-Value="peca.Nome" />
    </div>

    <div class="form-group">
        <label>Marca</label>
        <InputText class="form-control" @bind-Value="peca.Marca" />
    </div>

    <div class="form-group">
        <label>Fornecedor</label>
        <InputText class="form-control" @bind-Value="peca.Fornecedor" />
    </div>

    <div class="form-group">
        <label>Preço</label>
        <InputNumber class="form-control" @bind-Value="peca.Preco" />
    </div>

    <div class="form-group">
        <label>Estoque</label>
        <InputNumber class="form-control" @bind-Value="peca.QuantidadeEstoque" />
    </div>
    <!-- 📸 UPLOAD + PREVIEW -->
    <InputFile OnChange="PreviewImagem" accept="image/*" capture="environment" />

    @if (!string.IsNullOrEmpty(preview))
    {
        <img src="@preview" class="img-preview" />

        <button class="btn btn-primary mt-2" @onclick="UploadImagem">
            Salvar Imagem
        </button>
    }


    <button class="btn btn-success mt-3">Salvar</button>
    <button type="button" class="btn btn-secondary mt-3" @onclick="Voltar">Cancelar</button>
</EditForm>

@code {
    [Parameter] public int? id { get; set; }

    PecaDto peca = new();

    protected override async Task OnInitializedAsync()
    {
        if (id.HasValue)
        {
            var result = await Api.GetById(id.Value);
            if (result != null)
                peca = result;
        }
    }

    async Task Salvar()
    {
        if (id == null)
            await Api.Create(peca);
        else
            await Api.Update(peca.IdPeca, peca);

        Nav.NavigateTo("/pecas");
    }

    void Voltar() => Nav.NavigateTo("/pecas");
    string? preview;

    
    IBrowserFile? arquivo;

    // 📸 PREVIEW
    private async Task PreviewImagem(InputFileChangeEventArgs e)
    {
        arquivo = e.File;

        using var stream = arquivo.OpenReadStream(5_000_000);
        using var ms = new MemoryStream();

        await stream.CopyToAsync(ms);

        var base64 = Convert.ToBase64String(ms.ToArray());

        preview = $"data:{arquivo.ContentType};base64,{base64}";
    }

    private async Task UploadImagem()
    {
        if (arquivo == null)
            return;

        var content = new MultipartFormDataContent();
        content.Add(
            new StreamContent(arquivo.OpenReadStream(5_000_000)),
            "file",
            arquivo.Name
        );

        await Http.PostAsync($"api/peca/{peca.IdPeca}/upload", content);
    }

    public class UploadResult
    {
        public string Url { get; set; }
    }

}