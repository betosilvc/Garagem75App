@page "/veiculos/detalhe/{id:int}"
@attribute [Authorize(Roles = "Administrador,Mecanico")]
@using Garagem75.Shared.Dtos
@using Microsoft.AspNetCore.Authorization

@inject VeiculoApi Api
@inject NavigationManager Nav

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@700&display=swap');

    .cli-shell {
        --bg: #0f0f11;
        --surface: #18181c;
        --surface2: #222228;
        --border: rgba(255,255,255,0.07);
        --accent: #e8ff47;
        --text: #f0f0f0;
        --muted: #888888;
        --radius: 16px;
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        padding: 24px;
    }

    .detalhe-container {
        max-width: 500px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* CARD DE FOTO PRINCIPAL */
    .foto-frame {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        position: relative;
        aspect-ratio: 16 / 9;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .foto-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .sem-foto {
        color: var(--muted);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    /* CARD DE INFO */
    .info-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
    }

    .v-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
    }

    .v-title h3 { margin: 0; font-size: 22px; font-weight: 600; }
    .v-placa { 
        font-family: 'Space Mono', monospace; 
        background: var(--accent); 
        color: #000; 
        padding: 4px 10px; 
        border-radius: 6px; 
        font-size: 14px;
        font-weight: 700;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
    }
    .info-item:last-child { border-bottom: none; }
    .label { color: var(--muted); }
    .value { font-weight: 500; }

    /* UPLOAD AREA */
    .upload-area {
        background: var(--surface2);
        border: 1px dashed var(--border);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        margin-top: 10px;
    }

    .preview-thumbnail {
        width: 100%;
        border-radius: 10px;
        margin: 15px 0;
        border: 1px solid var(--accent);
    }

    /* BOTÕES */
    .cli-btn {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: opacity 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .btn-edit { background: var(--surface2); color: var(--text); border: 1px solid var(--border); margin-top: 10px;}
    .btn-save-photo { background: var(--accent); color: #000; margin-top: 10px;}

    /* Esconder o input file feio */
    .custom-file-upload {
        display: inline-block;
        padding: 8px 16px;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        font-size: 13px;
        color: var(--accent);
    }
</style>

<div class="cli-shell">
    <div class="detalhe-container">
        
        <div class="cli-title" @onclick='() => Nav.NavigateTo("/veiculos")' style="cursor:pointer">
            ⬅️ Detalhes<span>.</span>
        </div>

        @if (veiculo == null)
        {
            <div style="text-align:center; padding: 40px; color: var(--muted);">Carregando dados...</div>
        }
        else
        {
            <div class="foto-frame">
                @if (!string.IsNullOrEmpty(veiculo?.FotoUrl))
                {
                    <img src="@($"{ApiBase}/{veiculo.FotoUrl}")" class="foto-img" />
                }
                else
                {
                    <div class="sem-foto">
                        <span style="font-size: 40px;">📷</span>
                        <span>Nenhuma foto cadastrada</span>
                    </div>
                }
            </div>

            <div class="info-card">
                <div class="v-header">
                    <div class="v-title">
                        <h3>@veiculo.Fabricante @veiculo.Modelo</h3>
                    </div>
                    <div class="v-placa">@veiculo.Placa</div>
                </div>

                <div class="info-item">
                    <span class="label">Ano</span>
                    <span class="value">@veiculo.Ano</span>
                </div>
                <div class="info-item">
                    <span class="label">Cor</span>
                    <span class="value">@veiculo.Cor</span>
                </div>
                <div class="info-item">
                    <span class="label">Proprietário</span>
                    <span class="value" style="color: var(--accent)">@veiculo.ClienteNome</span>
                </div>

                <button class="cli-btn btn-edit" @onclick="Editar">
                    ✏️ Editar Informações
                </button>
            </div>

            <div class="info-card">
                <h5 style="font-size: 15px; margin-bottom: 15px;">Atualizar Foto do Veículo</h5>
                
                <div class="upload-area">
                    <label class="custom-file-upload">
                        <i class="bi bi-camera"></i> Selecionar ou Tirar Foto
                        <InputFile OnChange="PreviewFoto" accept="image/*" capture="environment" style="display:none;" />
                    </label>

                    @if (!string.IsNullOrEmpty(preview))
                    {
                        <img src="@preview" class="preview-thumbnail" />
                        <button class="cli-btn btn-save-photo" @onclick="SalvarFoto">
                            ✅ Confirmar e Salvar
                        </button>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    string ApiBase = "http://localhost:5244"; // Lembre de ajustar se mudar a porta da API
    [Parameter] public int id { get; set; }

    VeiculoDto? veiculo;

    protected override async Task OnInitializedAsync()
    {
        veiculo = await Api.GetById(id);
    }

    void Editar() => Nav.NavigateTo($"/veiculos/{id}");

    string? preview;
    IBrowserFile? arquivoSelecionado;

    async Task PreviewFoto(InputFileChangeEventArgs e)
    {
        arquivoSelecionado = e.File;
        var buffer = new byte[arquivoSelecionado.Size];
        await arquivoSelecionado.OpenReadStream().ReadAsync(buffer);
        preview = $"data:{arquivoSelecionado.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }

    async Task SalvarFoto()
    {
        try
        {
            if (arquivoSelecionado == null) return;

            var url = await Api.UploadFoto(id, arquivoSelecionado);

            if (!string.IsNullOrEmpty(url))
            {
                if (veiculo != null) veiculo.FotoUrl = url;
                preview = null;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }
}